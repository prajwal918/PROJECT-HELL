# OVERSEER Forex Edition
# Toxic Flow Arbitrage Engine for MT4/MT5

# ============================================
# TELEGRAM
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# MT5 BROKER
# ============================================
MT5_ACCOUNT=12345678
MT5_PASSWORD=your_password
MT5_SERVER=ICMarkets-Demo
MT5_PATH=/path/to/terminal64.exe

# ============================================
# RISK MANAGEMENT
# ============================================
RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_WEEKLY_LOSS_PCT=6.0
MAX_DAILY_TRADES=3
MAX_CONSECUTIVE_LOSSES=2
MIN_RR_RATIO=1.5
MAX_CORRELATION_EXPOSURE=2

# ============================================
# ZMQ BRIDGE
# ============================================
ZMQ_HOST=127.0.0.1
ZMQ_PORT=5555

# ============================================
# GATE THRESHOLDS
# ============================================
MIN_QUALITY_SCORE=0.65
MIN_GATE_B_SCORE=6
MIN_ATR_PIPS=2.0
MAX_SPREAD_PIPS=2.0
LAG_THRESHOLD_PIPS=1.5

# ============================================
# SESSION TIMES (UTC)
# ============================================
LONDON_OPEN=7
LONDON_CLOSE=16
NY_OPEN=12
NY_CLOSE=21
ASIAN_OPEN=0
ASIAN_CLOSE=8

# ============================================
# KILL ZONES (UTC)
# ============================================
KZ_LONDON_PRIME_START=3
KZ_LONDON_PRIME_END=4
KZ_NY_OPEN_START=9.5
KZ_NY_OPEN_END=10.5
KZ_LONDON_CLOSE_START=11
KZ_LONDON_CLOSE_END=12
KZ_ASIAN_START=20
KZ_ASIAN_END=21

# ============================================
# DATABASE
# ============================================
DB_PATH=./data/trades.db
STATE_PATH=./data/state.json

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_PATH=./logs/overseer.log
# ============================================
# CQG AMPConnect WebAPI (Level 2 / detailed DOM feed bridge)
# Set CQG_ENABLED=true and fill credentials to stream from CQG directly.
# The bridge publishes to the same ZMQ topic OVERSEER_L3 that OVERSEER reads.
# ============================================
CQG_ENABLED=false
CQG_HOST=wss://demoapi.cqg.com:443
CQG_USERNAME=your_cqg_username
CQG_PASSWORD=your_cqg_password
CQG_CLIENT_APP_ID=WebAPITest
CQG_CLIENT_VERSION=python-client-test-2-230
CQG_PROTOCOL_VERSION_MAJOR=2
CQG_PROTOCOL_VERSION_MINOR=230
CQG_SYMBOLS=6E,6B,6J,ES,NQ,CL,GC
CQG_REALTIME_LEVEL=7
CQG_RECONNECT_MIN=1.0
CQG_RECONNECT_MAX=60.0
CQG_ZMQ_PUBLISH_HOST=*
CQG_ZMQ_PUBLISH_PORT=5555

